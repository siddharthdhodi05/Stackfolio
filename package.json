{
  "name": "showstack",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "siddharth",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "node server/main.js",
    "server": "nodemon --env-file=.env server/main.js",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "data:import": "node server/seeder",
    "data:destroy": "node server/seeder -d"
  },
  "imports": {
    "#config/*": "./server/config/*",
    "#data/*": "./server/data/*",
    "#models/*": "./server/models/*",
    "#middleware/*": "./server/middleware/*",
    "#controllers/*": "./server/controllers/*",
    "#routes/*": "./server/routes/*",
    "#utils/*": "./server/utils/*"
  },
  "dependencies": {
    "@babel/preset-env": "^7.29.7",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "colors": "^1.4.0",
    "concurrently": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.3",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "nodemon": "^3.1.14",
    "streamifier": "^0.1.1"
  }
}
